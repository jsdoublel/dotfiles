#!/usr/bin/env bash
# James Willson 2026

SEARCH_PATHS=("$HOME")

command -v bat > /dev/null && FILES_PREVIEW="bat --color=always --style=plain {}" || FILES_PREVIEW="cat {}"
command -v lsd >/dev/null && FOLDERS_PREVIEW="lsd --tree --depth=3 --color=always --icon=always {}" || FOLDERS_PREVIEW="ls --color=always {}"

fzf_command() {
	fzf --style 'full:rounded' --border rounded --border-label "$1" --preview="$2"
}

# Asks for a directory and launches kitty there (two tabs, one for editor:
# nvim, and one for shell). Tries to reuse current terminal window if current
# window only has 1 tab; otherwise, launches a new window
lkitty() {
	local dir # project directory
	local new_tab_id # id of new kitty tab
	[[ -z $1 ]] && dir=$(fd . "${SEARCH_PATHS[@]}" -t d | fzf_command ' KITTY ' "$FOLDERS_PREVIEW") || dir="$1"
	[[ -z $dir ]] && exit 1
	new_tab_id=$(kitty @ launch --type=tab --cwd="$dir" nvim .)
	kitty @ set-tab-title --match "id:$new_tab_id" "$(basename "$dir")"
	kitty @ launch --match "id:$new_tab_id" --type=window --cwd="$dir" bash > /dev/null
	kitty @ focus-window --match "id:$new_tab_id"
}

# Asks for file and launches editor in new tab.
leditor() {
	local file # file to open
	file=$(fd . "${SEARCH_PATHS[@]}" -t f | fzf_command " ${EDITOR^^} " "$FILES_PREVIEW")
	[[ -z $file ]] && exit 1
	kitty @ set-tab-title --match "id:$KITTY_WINDOW_ID" "$(basename "$file")"
	$EDITOR "$file"
}

# Asks for directory and launches file browser (with exo-open). I tried the
# more generic xdg-open, but I couldn't get it to work, as it would leave a
# blank terminal window.
ldir() {
	local dir # directory to open 
	[[ -z "$1" ]] && dir=$(fd . "${SEARCH_PATHS[@]}" -t d | fzf_command ' THUNAR ' "$FOLDERS_PREVIEW") || dir="$1"
	[[ -z $dir ]] && exit 1
	setsid exo-open "$dir" >/dev/null 2>&1
}

##################
# Parse Arguments
##################

_usage() {
	echo "Usage: lkitty [-d directory -feh]"
	echo ""
	echo "Options:"
	echo "	-d, --directory DIR   Specify the directory"
	echo "	-f, --file-manager    Launches file-manager (instead of kitty)"
	echo "	-e, --editor          Launches nvim (instead of kitty)"
	echo "	-h, --help            Display this help message"
}

dir=""
e=false
f=false

ARGS=d:efh
LARGS=directory:,editor,file-manager,help
parse=$(getopt --options $ARGS --longoptions $LARGS --name "lkitty" -- "$@")
if [[ $? != 0 ]]; then
	exit 1
fi
eval set -- "$parse"

while true; do
	case "$1" in
	-d | --directory) dir="$2"; shift 2 ;;
	-e | --editor) e=true; shift ;;
	-f | --file-manager) f=true; shift ;;
	-h | --help) _usage; exit 0 ;;
	--) shift; break ;;
	*) echo "Error: $1"; exit 1 ;;
	esac
done

if [[ -z "$KITTY_PID" ]]; then
	echo "Error: Must be launched using kitty as your terminal."
	exit 1
fi

if (( $# > 0 )); then
	echo "Invalid option(s) $*"
	_usage
	exit 1
fi

if $e; then
	leditor
elif $f; then
	ldir "$dir"
else 
	lkitty "$dir"
fi

