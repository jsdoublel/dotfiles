#!/usr/bin/env bash
# James Willson 2026

SEARCH_PATHS=("$HOME")

if command -v bat > /dev/null 2>&1; then 
	FILES_PREVIEW="bat --color=always --style=plain {}"
else
	FILES_PREVIEW="cat {}"
fi
if command -v lsd >/dev/null 2>&1; then
	FOLDERS_PREVIEW="lsd --tree --depth=3 --color=always --icon=always {}"
else
	FOLDERS_PREVIEW="ls --color=always {}"
fi

fzf_command() {
	fzf --style 'full:rounded' --border rounded --border-label "$1" --preview="$2"
}

# Asks for a directory and launches kitty there (two tabs, one for editor:
# nvim, and one for shell). Tries to reuse current terminal window if current
# window only has 1 tab; otherwise, launches a new window
lkitty() {
	local dir # project directory
	local ltype # type of kitty launch
	local nvim_id # id of nvim kitty tab
	[[ -z $1 ]] && dir=$(fd . "${SEARCH_PATHS[@]}" -t d | fzf_command ' KITTY ' "$FOLDERS_PREVIEW") || dir="$1"
	[[ -z $dir ]] && exit 1
	[[ $(kitty @ ls | jq ".[] | select(.is_focused) | .tabs | length") == "1" ]] && ltype="overlay" || ltype="os-window"
	nvim_id=$(kitty @ launch --type="$ltype" --cwd="$dir" nvim .)
	kitty @ set-tab-title --match "id:$nvim_id" "nvim"
	kitty @ launch --match "id:$nvim_id" --type=tab --cwd="$dir" bash > /dev/null
	kitty @ focus-window --match "id:$nvim_id"
}

# Asks for file and launches editor (nvim) in new tab.
lvim() {
	local file # file to open
	file=$(fd . "${SEARCH_PATHS[@]}" -t f | fzf_command ' NVIM ' "$FILES_PREVIEW")
	[[ -z $file ]] && exit 1
	kitty @ set-tab-title --match "id:$KITTY_WINDOW_ID" "$(basename "$file")"
	nvim "$file"
}

# Asks for directory and launches file browser (with exo-open). I tried the
# more generic xdg-open, but I couldn't get it to work, as it would leave a
# blank terminal window.
ldir() {
	local dir # directory to open 
	dir=$(fd . "${SEARCH_PATHS[@]}" -t d | fzf_command ' THUNAR ' "$FOLDERS_PREVIEW")
	[[ -z $dir ]] && exit 1
	setsid exo-open "$dir" >/dev/null 2>&1 
}

##################
# Parse Arguments
##################

_usage() {
	echo "Usage: lkitty [options]"
	echo ""
	echo "Options:"
	echo "	-d, --directory DIR   Specify the directory"
	echo "	-f, --file-manager    Launches file-manager (instead of tmux)"
	echo "	-v, --vim             Launches nvim (instead of tmux)"
	echo "	-h, --help            Display this help message"
}

dir=""
v=false
f=false

ARGS=d:vfh
LARGS=directory:,vim,file-manager,help
parse=$(getopt --options $ARGS --longoptions $LARGS --name "lkitty" -- "$@")
if [[ $? != 0 ]]; then
	exit 1
fi
eval set -- "$parse"

while true; do
	case "$1" in
	-d | --directory)
		dir="$2"
		shift 2
		;;
	-v | --vim)
		v=true
		shift 
		;;
	-f | --file-manager)
	f=true
	shift
	;;
	-h | --help)
		_usage
		exit 0
		;;
	--)
		shift
		break
		;;
	*)
		echo "error: $1"
		exit 1
		;;
	esac
done

if [ ! -n "$KITTY_PID" ]; then
	echo "Error: Must be launched using kitty as your terminal."
	exit 1
fi
if [ ! -z "$@" ]; then
	echo "Invalid option(s) \"$@\""
	_usage
	exit 1
fi

if $v; then
	lvim
elif $f; then
	ldir
else 
	lkitty "$dir"
fi

