#!/usr/bin/env bash
# James Willson 2025

SEARCH_PATHS=("$HOME")

FILES_PREVIEW="bat --color=always --style=plain {}"
if command -v lsd >/dev/null 2>&1; then
  FOLDERS_PREVIEW="lsd --tree --depth=3 --color=always --icon=always {}"
else
  FOLDERS_PREVIEW="ls --color=always {}"
fi

fzf_command() {
	fzf --style 'full:rounded' --border rounded --border-label "$1" --preview="$2"
}

lkitty() {
  [[ -z $1 ]] && d=$(fd . "${SEARCH_PATHS[@]}" -t d | fzf_command ' KITTY ' "$FOLDERS_PREVIEW") || d="$1"
  [[ -z $d ]] && exit 1
  [[ $(kitty @ ls | jq '.[] | select(.is_focused) | .tabs | length') -gt 1 ]] && ltype="os-window" || ltype="overlay-main"
  nvim_id=$(kitty @ launch --type="$ltype" --cwd="$d" nvim .)
  kitty @ launch --type=tab --cwd="$d" bash > /dev/null
  kitty @ focus-window --match "id:$nvim_id"
}

lvim() {
  f=$(fd . "${SEARCH_PATHS[@]}" -t f | fzf_command ' NVIM ' "$FILES_PREVIEW")
  [[ -z $f ]] && exit 1
  nvim "$f"
}

ldir() {
  f=$(fd . "${SEARCH_PATHS[@]}" -t d | fzf_command ' THUNAR ' "$FOLDERS_PREVIEW")
  [[ -z $f ]] && exit 1
  setsid exo-open "$f" >/dev/null 2>&1 
}

_usage() {
  echo "Usage: lkitty [options]"
  echo ""
  echo "Options:"
  echo "  -d, --directory DIR   Specify the directory"
  echo "  -f, --file-manager    Launches file-manager (instead of tmux)"
  echo "  -v, --vim             Launches nvim (instead of tmux)"
  echo "  -h, --help            Display this help message"
}

dir=""
v=false
f=false

ARGS=d:vfh
LARGS=directory:,vim,file-manager,help
parse=$(getopt --options $ARGS --longoptions $LARGS --name "lkitty" -- "$@")
if [[ $? != 0 ]]; then
  exit 1
fi
eval set -- "$parse"

while true; do
  case "$1" in
  -d | --directory)
    dir="$2"
    shift 2
    ;;
  -v | --vim)
    v=true
    shift 
    ;;
  -f | --file-manager)
	f=true
	shift
	;;
  -h | --help)
    _usage
    exit 0
    ;;
  --)
    shift
    break
    ;;
  *)
    echo "error: $1"
    exit 1
    ;;
  esac
done

if [ ! -n "$KITTY_PID" ]; then
  echo "Error: Must be launched using kitty as your terminal."
  exit 1
fi
if [ ! -z "$@" ]; then
  echo "Invalid option(s) \"$@\""
  _usage
  exit 1
fi

if $v; then
	lvim
elif $f; then
	ldir
else 
	lkitty "$dir"
fi

